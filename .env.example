# Copy this file to `.env.local` and fill in your keys, then restart `npm run dev`.

# Required — powers the AI Scenario Simulator (/simulate).
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional — enables spoken narration ("🔊 speak") of scenario results.
# Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
